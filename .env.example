# --------------------------------------------
# Global Settings
# --------------------------------------------
DOMAIN=example.com
ACME_EMAIL=admin@example.com
TZ=Asia/Kolkata

# --------------------------------------------
# Traefik (proxy/compose.yml)
# --------------------------------------------
TRAEFIK_IMAGE=traefik:v3.6

# --------------------------------------------
# Authelia
# --------------------------------------------
AUTHELIA_IMAGE=authelia/authelia:4.39.16
# Authelia secrets and the users database live in auth/secrets/, not in .env.

# --------------------------------------------
# Homarr
# --------------------------------------------
HOMARR_IMAGE=ghcr.io/homarr-labs/homarr:v1.44.0
HOMARR_SECRET_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# --------------------------------------------
# Observability
# --------------------------------------------
PROMETHEUS_IMAGE=prom/prometheus:v3.5.1
GRAFANA_IMAGE=grafana/grafana:12.3.1
ALERTMANAGER_IMAGE=prom/alertmanager:v0.30.0
BLACKBOX_EXPORTER_IMAGE=quay.io/prometheus/blackbox-exporter:v0.28.0
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.10.2
